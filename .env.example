OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_LLM_MODEL=llama3.2

CHROMA_PERSIST_PATH=./data/chroma
CHROMA_COLLECTION_NAME=localrag

CHUNK_CHARS=512
CHUNK_OVERLAP_CHARS=50
EMBEDDING_BATCH_SIZE=32

INGEST_RECURSIVE=true
INGEST_ROOTS=[]

RAG_TOP_K=5
RAG_SYSTEM_PROMPT=You are a helpful assistant. Answer only based on the provided context.

API_HOST=0.0.0.0
API_PORT=8000

# Set to a non-empty string to require X-API-Key header on all non-health endpoints.
# Leave empty to disable authentication (default).
API_KEY=

# LLM backend: ollama | openai | anthropic
LLM_BACKEND=ollama

# Canonical embedding model alias (overrides OLLAMA_EMBED_MODEL when set).
EMBEDDING_MODEL=

# OpenAI provider (only used when LLM_BACKEND=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic provider (only used when LLM_BACKEND=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
